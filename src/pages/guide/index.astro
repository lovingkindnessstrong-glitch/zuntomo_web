---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { Image } from 'astro:assets';

// 初めての方へページ用のヒーロー画像をインポート
import guideHero from '../../assets/images/guide/Friendly-Reception-ZUMBA.webp';

const breadcrumbItems = [
  { label: 'ホーム', href: '/' },
  { label: '初めての方へ（参加ガイド）' },
];
---

<Layout title="初めての方へ（参加ガイド） | ZUNTOMO">
  <main class="bg-slate-50 pb-16">
    
    {/* ヒーローエリア */}
    <section class="relative w-full h-[400px] overflow-hidden flex flex-col items-center justify-center text-center px-4">
      
      {/* 背景画像：顔が見切れないよう、上から20%を基準に表示（object-[center_20%]） */}
      <Image 
        src={guideHero} 
        alt="初心者でも安心！予約不要で参加できるズンともの受付の様子" 
        class="absolute inset-0 h-full w-full object-cover object-[center_20%]"
      />

      {/* テキストを読みやすくするための半透明オーバーレイ */}
      <div class="absolute inset-0 bg-blue-900/60 mix-blend-multiply"></div>
      
      <div class="relative z-10 max-w-3xl mx-auto mt-12">
        <h1 class="text-3xl md:text-5xl font-bold text-white mb-6 drop-shadow-[0_4px_4px_rgba(0,0,0,0.8)] tracking-wide">
          初めての方へ
        </h1>
        <p class="text-lg md:text-xl text-blue-50 font-medium leading-relaxed drop-shadow-[0_2px_2px_rgba(0,0,0,0.8)]">
          予約なしでフラッと参加OK！<br class="hidden md:block" />あなたのペースで楽しめるアットホームな空間です。
        </p>
      </div>
    </section>

    <div class="container mx-auto px-4 -mt-8 relative z-20 max-w-5xl">
      <Breadcrumb items={breadcrumbItems} />

      {/* リード文 */}
      <section class="bg-white rounded-2xl shadow-sm p-8 md:p-12 mb-12 text-center mt-6 border-t-4 border-blue-400">
        <p class="text-lg text-slate-700 leading-relaxed max-w-3xl mx-auto">
          初めての場所に行くときは、誰でも緊張するものです。<br />
          ダンスサークル「ズンとも」は、面倒な入会手続きや事前予約は一切不要。<br />
          <strong class="text-blue-600 font-bold">「今日、ちょっと運動したいな」</strong>と思い立ったときに、着替えと室内シューズだけ持ってフラッと立ち寄れる気軽なサークルです。<br /><br />
          お一人でのご参加も大歓迎！年齢・性別・経験問わず、いつでも温かくお迎えします。
        </p>
      </section>

      {/* 持ち物 */}
      <section class="mb-16">
        <div class="text-center mb-10">
          <h2 class="inline-block text-3xl font-bold text-slate-800 relative pb-3">
            🎒 持ち物・服装
            <span class="absolute bottom-0 left-0 w-full h-1 bg-gradient-to-r from-blue-400 to-emerald-400 rounded"></span>
          </h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-100 text-center flex flex-col items-center">
            <div class="w-16 h-16 bg-blue-50 text-blue-500 rounded-full flex items-center justify-center text-3xl mb-4">👟</div>
            <h3 class="font-bold text-slate-800 mb-2">室内シューズ（必須）</h3>
            <p class="text-sm text-slate-600 leading-relaxed">体育館やスタジオを使用するため、必ずご持参ください。</p>
          </div>
          <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-100 text-center flex flex-col items-center">
            <div class="w-16 h-16 bg-blue-50 text-blue-500 rounded-full flex items-center justify-center text-3xl mb-4">💧</div>
            <h3 class="font-bold text-slate-800 mb-2">飲み物</h3>
            <p class="text-sm text-slate-600 leading-relaxed">たっぷり汗をかくため、多めの水分（水やスポーツドリンク）をお持ちください。</p>
          </div>
          <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-100 text-center flex flex-col items-center">
            <div class="w-16 h-16 bg-blue-50 text-blue-500 rounded-full flex items-center justify-center text-3xl mb-4">🧣</div>
            <h3 class="font-bold text-slate-800 mb-2">汗拭きタオル</h3>
            <p class="text-sm text-slate-600 leading-relaxed">運動中はかなり汗をかきます。首からかけられるサイズが便利です。</p>
          </div>
          <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-100 text-center flex flex-col items-center">
            <div class="w-16 h-16 bg-blue-50 text-blue-500 rounded-full flex items-center justify-center text-3xl mb-4">👕</div>
            <h3 class="font-bold text-slate-800 mb-2">動きやすい服装</h3>
            <p class="text-sm text-slate-600 leading-relaxed">Tシャツやジャージなど、ご自身が動きやすい服装でOK（専用ウェアは不要です）。</p>
          </div>
        </div>
      </section>

      {/* 当日の流れ */}
      <section class="mb-16">
        <div class="text-center mb-10">
          <h2 class="inline-block text-3xl font-bold text-slate-800 relative pb-3">
            👣 当日の流れ
            <span class="absolute bottom-0 left-0 w-full h-1 bg-gradient-to-r from-emerald-400 to-blue-400 rounded"></span>
          </h2>
        </div>

        <div class="bg-white rounded-2xl shadow-sm p-6 md:p-10 border border-slate-100">
          <div class="space-y-8 md:space-y-12">
            
            {/* Step 1 */}
            <div class="flex flex-col md:flex-row gap-6 items-start">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-blue-500 text-white font-bold text-xl flex items-center justify-center shadow-md">
                1
              </div>
              <div>
                <h3 class="text-xl font-bold text-slate-800 mb-3">直接会場へ・受付 <span class="text-sm font-normal text-slate-500 ml-2">※開始10〜15分前推奨</span></h3>
                <p class="text-slate-700 leading-relaxed">
                  事前予約は不要です。直接会場にお越しください。初めての方は、受付で「初めてです」とお声がけいただければ、スタッフがご案内します。<br />
                  初回のみ、簡単な参加同意書へのご記入をお願いしています。また、参加費（500円）のお支払いと引き換えに、無料特典がもらえるポイントカードを発行します。
                </p>
              </div>
            </div>

            {/* Step 2 */}
            <div class="flex flex-col md:flex-row gap-6 items-start">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-emerald-500 text-white font-bold text-xl flex items-center justify-center shadow-md">
                2
              </div>
              <div>
                <h3 class="text-xl font-bold text-slate-800 mb-3">お着替え・準備</h3>
                <p class="text-slate-700 leading-relaxed">
                  各会場には更衣室（男女別）がございます。動きやすい服装に着替え、室内シューズに履き替えてお待ちください。
                </p>
              </div>
            </div>

            {/* Step 3 */}
            <div class="flex flex-col md:flex-row gap-6 items-start">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-orange-500 text-white font-bold text-xl flex items-center justify-center shadow-md">
                3
              </div>
              <div>
                <h3 class="text-xl font-bold text-slate-800 mb-3">レッスンスタート！</h3>
                <p class="text-slate-700 leading-relaxed">
                  インストラクターの動きを見よう見まねで動くだけでOK！間違えても全く問題ありません。音楽に合わせて、ご自身のペースで無理なく楽しんでください。終了後はそのまま解散となります。
                </p>
              </div>
            </div>

          </div>
        </div>
      </section>

      {/* 会場設備について（ご留意事項） */}
      <section class="mb-16">
        <div class="bg-amber-50 rounded-2xl p-8 border-l-4 border-amber-500">
          <h2 class="text-2xl font-bold text-amber-900 mb-4 flex items-center gap-2">
            <span>🏫</span> 会場設備に関するお願い
          </h2>
          <p class="text-amber-800 leading-relaxed mb-4">
            ズンともは、地域の公共施設（体育館やコミュニティセンターなど）をお借りして活動し、参加費をワンコイン（500円）に抑えています。そのため、以下の点にご理解とご協力をお願いいたします。
          </p>
          <ul class="list-disc list-inside text-amber-800 space-y-2 ml-2">
            <li><strong>自動販売機がない場合があります:</strong> 会場によっては館内に自販機がありません。飲み物は事前に多めにご用意ください。</li>
            <li><strong>冷暖房設備について:</strong> 季節に合わせて工夫しておりますが、一部施設（函南町西部コミュニティセンターなど）は冷暖房設備がありません。<br><span class="text-sm ml-5 opacity-80">※真夏のみ、熱中症対策として冷房完備の別施設へ移動して開催しています。</span></li>
          </ul>
        </div>
      </section>

      {/* FAQ */}
      <section class="mb-16">
        <div class="text-center mb-10">
          <h2 class="inline-block text-3xl font-bold text-slate-800 relative pb-3">
            ❓ よくあるご質問
            <span class="absolute bottom-0 left-0 w-full h-1 bg-gradient-to-r from-blue-400 to-emerald-400 rounded"></span>
          </h2>
        </div>

        <div class="space-y-4">
          <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6">
            <h3 class="text-lg font-bold text-blue-700 mb-2 flex gap-3 items-start">
              <span class="flex-shrink-0">Q.</span>
              <span>全くの初心者で、ダンス経験がありませんが大丈夫ですか？</span>
            </h3>
            <p class="text-slate-700 flex gap-3 items-start ml-1">
              <span class="font-bold text-emerald-600 flex-shrink-0">A.</span>
              <span>はい、大歓迎です！参加者の多くが未経験からスタートしています。振り付けを完璧に覚える必要はありません。「音楽に乗って楽しく体を動かす」ことが一番の目的です。</span>
            </p>
          </div>

          <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6">
            <h3 class="text-lg font-bold text-blue-700 mb-2 flex gap-3 items-start">
              <span class="flex-shrink-0">Q.</span>
              <span>1人で参加しても浮きませんか？</span>
            </h3>
            <p class="text-slate-700 flex gap-3 items-start ml-1">
              <span class="font-bold text-emerald-600 flex-shrink-0">A.</span>
              <span>ほとんどの方がお1人で参加されています。レッスン中は音楽とダンスに集中できるため、周りの目は気になりません。安心してお越しください。</span>
            </p>
          </div>

          <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6">
            <h3 class="text-lg font-bold text-blue-700 mb-2 flex gap-3 items-start">
              <span class="flex-shrink-0">Q.</span>
              <span>体力に自信がないのですが…</span>
            </h3>
            <p class="text-slate-700 flex gap-3 items-start ml-1">
              <span class="font-bold text-emerald-600 flex-shrink-0">A.</span>
              <span>ご自身のペースで動いていただければ大丈夫です。疲れたら途中で休んだり、水分補給をしていただいて全く問題ありません。</span>
            </p>
          </div>
        </div>
      </section>

      {/* CVエリア */}
      <section class="bg-gradient-to-r from-blue-500 to-emerald-400 rounded-2xl p-8 md:p-12 text-center shadow-lg">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-6 leading-tight">
          「ちょっと気になる」「行く前に聞いておきたい」<br class="hidden md:block" />
          そんな方はお気軽にご連絡ください！
        </h2>
        <p class="text-blue-50 text-lg mb-8 max-w-2xl mx-auto leading-relaxed">
          どんな小さな疑問も公式LINEで受付中！インストラクターが直接丁寧にお答えします。
        </p>
        
        {/* エラー回避のため <a> タグに直接クラスを指定してスタイリング */}
        <a href="#" class="inline-flex items-center justify-center bg-white text-blue-600 font-bold hover:bg-slate-50 shadow-md text-lg px-8 py-3 rounded-full transition-all hover:scale-105">
          LINEで今すぐ相談・体験申込
        </a>
      </section>

    </div>
  </main>
</Layout>