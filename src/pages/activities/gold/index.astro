---
import Layout from '../../../layouts/Layout.astro';
import Button from '../../../components/Button.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { Image } from 'astro:assets';

// ゴールド用のヒーロー画像をインポート
import goldHero from '../../../assets/images/activities/gold/gold-hero-1200.webp';

// 出張レッスンの画像をインポート
import volunteerImg from '../../../assets/images/activities/gold/volunteer.webp';

const breadcrumbItems = [
  { label: 'ホーム', href: '/' },
  { label: 'レッスン', href: '/#lesson' },
  { label: 'ゴールドクラス' },
];
---

<Layout title="ゴールドクラス（S-DANCE™ GOLD） | ZUNTOMO">
  <main class="bg-gradient-to-b from-blue-50 to-white">
    
    {/* ① ヒーローエリア */}
    <section class="relative w-full h-96 overflow-hidden flex flex-col items-center justify-center text-center px-4">
      {/* 背景画像 */}
      <Image 
        src={goldHero} 
        alt="ゴールドクラスの様子" 
        class="absolute inset-0 h-full w-full object-cover object-center"
      />
      {/* 青みを無くし、写真本来の暖かさを活かすシンプルな黒の半透明に変更 */}
      <div class="absolute inset-0 bg-black/50"></div>
      
      {/* テキストコンテンツ */}
      <div class="relative z-10">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4 drop-shadow-[0_4px_4px_rgba(0,0,0,0.8)]">
          めちゃめちゃ楽しく運動しよう！
        </h1>
        <p class="text-lg md:text-xl text-yellow-100 max-w-3xl drop-shadow-[0_2px_2px_rgba(0,0,0,0.8)]">
          誰もが知っているあの曲で。心も体も、そして脳もイキイキ若返る特別な60分。
        </p>
      </div>
    </section>

    <Breadcrumb items={breadcrumbItems} />

    <div class="container mx-auto px-4 py-12 max-w-5xl">
      
      {/* ② コンセプト・誕生ストーリー */}
      <section class="mb-16">
        <h2 class="text-3xl font-bold text-blue-800 border-b-4 border-yellow-400 pb-3 mb-6">
          🎵 音楽と笑顔で、誰も置き去りにしないフィットネスを。
        </h2>
        <div class="bg-blue-50 rounded-lg p-6 shadow-md">
          <p class="text-gray-700 text-lg leading-relaxed mb-4">
            インストラクター自身の「高齢の母親をなんとか運動させたい」と、母親の「運動はやりたくない」から、
            シニアの方やハンディキャップがある方でも「心から楽しめるような運動指導をしたい！」という強い想いでスタートしました。
          </p>
          <p class="text-gray-700 text-lg leading-relaxed mb-4">
            どんな年齢でも心から楽しんでいただくため、<strong class="text-blue-700">みんなが知っていて口ずさめる流行曲やポップス</strong>を中心に、
            独自のプログラム「<span class="font-bold text-yellow-600">S-DANCE™ GOLD</span>」を開発しました。
          </p>
          <p class="text-gray-700 text-lg leading-relaxed">
            運動だけでなく、<strong class="text-purple-600">「シナプソロジー®️（脳トレ）」</strong>や
            <strong class="text-orange-600">「バランスボール」</strong>を取り入れ、
            心身機能の維持向上と、脳の活性化を同時に図っています。
          </p>
        </div>
      </section>

      {/* ③ 対象者・こんな方におすすめ */}
      <section class="mb-16">
        <h2 class="text-3xl font-bold text-blue-800 border-b-4 border-yellow-400 pb-3 mb-6">
          👴👵 どなたでも参加可能！あなたのペースで楽しめます
        </h2>
        <div class="bg-white rounded-lg shadow-md p-6 mb-6">
          <ul class="space-y-3 text-gray-700 text-lg">
            <li class="flex items-start">
              <span class="text-yellow-500 mr-2 text-2xl">✓</span>
              <span><strong class="text-blue-700">健康寿命を延ばしたい</strong>アクティブシニアの方</span>
            </li>
            <li class="flex items-start">
              <span class="text-yellow-500 mr-2 text-2xl">✓</span>
              <span><strong class="text-blue-700">心身にハンディキャップのある方</strong>（車椅子でのご参加も大歓迎です！）</span>
            </li>
            <li class="flex items-start">
              <span class="text-yellow-500 mr-2 text-2xl">✓</span>
              <span><strong class="text-blue-700">医師から運動を勧められている方</strong>、または久しぶりに運動する方</span>
            </li>
            <li class="flex items-start">
              <span class="text-yellow-500 mr-2 text-2xl">✓</span>
              <span><strong class="text-blue-700">リハビリの延長として</strong>楽しく体を動かしたい方</span>
            </li>
          </ul>
        </div>
        <div class="flex flex-wrap gap-3">
          <span class="bg-gradient-to-r from-blue-500 to-blue-600 text-white px-4 py-2 rounded-full text-sm font-bold shadow-md">S-Dance™GOLD</span>
          <span class="bg-gradient-to-r from-purple-500 to-purple-600 text-white px-4 py-2 rounded-full text-sm font-bold shadow-md">シナプソロジー®️</span>
          <span class="bg-gradient-to-r from-pink-500 to-pink-600 text-white px-4 py-2 rounded-full text-sm font-bold shadow-md">脳トレ</span>
          <span class="bg-gradient-to-r from-green-500 to-green-600 text-white px-4 py-2 rounded-full text-sm font-bold shadow-md">リハビリ</span>
          <span class="bg-gradient-to-r from-orange-500 to-orange-600 text-white px-4 py-2 rounded-full text-sm font-bold shadow-md">バランスボール</span>
          <span class="bg-gradient-to-r from-red-500 to-red-600 text-white px-4 py-2 rounded-full text-sm font-bold shadow-md">車椅子OK</span>
        </div>
      </section>

      {/* ④ スケジュールと参加案内 */}
      <section class="mb-16">
        <h2 class="text-3xl font-bold text-blue-800 border-b-4 border-yellow-400 pb-3 mb-6">
          🎯 S-Dance™ GOLD クラス詳細
        </h2>
        
        <div class="bg-gradient-to-br from-blue-500 to-blue-600 rounded-lg shadow-xl p-8 text-white mb-8">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-white rounded-lg p-5 shadow-md">
              <h3 class="text-gray-800 font-bold text-xl mb-2">📅 開催日時</h3>
              <p class="text-2xl font-bold text-blue-700">日曜日 13:30〜14:30</p>
              <p class="text-gray-700">60分 ※月1回・不定期開催</p>
            </div>
            <div class="bg-white rounded-lg p-5 shadow-md">
              <h3 class="text-gray-800 font-bold text-xl mb-2">📍 会場</h3>
              <p class="text-2xl font-bold text-blue-700">沼津市総合体育館</p>
              <p class="text-gray-700">2F 多目的スタジオ</p>
            </div>
            <div class="bg-white rounded-lg p-5 shadow-md">
              <h3 class="text-gray-800 font-bold text-xl mb-2">💰 料金</h3>
              <p class="text-3xl font-bold text-red-600">500円</p>
              <p class="text-gray-700">現金都度払い</p>
            </div>
            <div class="bg-white rounded-lg p-5 shadow-md">
              <h3 class="text-gray-800 font-bold text-xl mb-2">🎫 参加方法</h3>
              <p class="text-2xl font-bold text-blue-700">事前予約不要</p>
              <p class="text-gray-700">13時のドアオープン以降、直接現地にお越しください</p>
            </div>
          </div>
        </div>

        {/* 出張レッスンの実績（B2C向けの安心感アピールとして再構成） */}
        <div class="bg-white border-2 border-blue-100 rounded-xl p-6 md:p-8 shadow-sm flex flex-col md:flex-row gap-8 items-center">
          <div class="md:w-1/2">
            <h4 class="font-bold text-blue-800 text-xl mb-4 flex items-center gap-2">
              <span class="text-2xl">🤝</span> 安心・安全なプログラム設計
            </h4>
            <p class="text-gray-700 leading-relaxed mb-4">
              S-DANCE™ GOLDは、参加される方の年齢や体力、車椅子等の状況に合わせた安全なプログラムです。
            </p>
            <p class="text-gray-700 leading-relaxed mb-4">
              その安全性・楽しさが評価され、障害者サポート団体様や高齢者施設様、親子レッスンから中年男性のメタボ対策まで、出張レッスンも多数承っております。運動に不安がある方も、どうぞ安心してご参加ください。
            </p>
            <p class="text-sm text-gray-500">
              ※自治体・施設担当者様向けの出張依頼については、<a href="/about/" class="text-blue-600 underline hover:text-blue-800 transition-colors">運営者紹介ページ</a>をご覧ください。
            </p>
          </div>
          <div class="md:w-1/2 w-full">
            <div class="rounded-xl overflow-hidden shadow-md border-2 border-white">
              <Image 
                src={volunteerImg} 
                alt="高齢者施設やサポート団体様での出張レッスンの様子" 
                class="w-full h-auto object-cover"
              />
            </div>
            <p class="text-xs text-gray-500 mt-2 text-center">
              ▲ 約80名の障害者のみなさまと楽しくレクリエーション。
          </div>
        </div>
      </section>

      {/* ⑤ 特徴セクション */}
      <section class="mb-16">
        <h2 class="text-3xl font-bold text-blue-800 border-b-4 border-yellow-400 pb-3 mb-6">
          ✨ S-DANCE™ GOLDの3つの特徴
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-gradient-to-br from-yellow-100 to-yellow-50 rounded-lg p-6 shadow-md border-t-4 border-yellow-500">
            <div class="text-5xl mb-4 text-center">🎵</div>
            <h3 class="text-xl font-bold text-blue-800 mb-3 text-center">誰もが知る名曲で</h3>
            <p class="text-gray-700 text-center">
              懐かしい流行曲やポップスで、自然と体が動き出す。口ずさみながら楽しく運動できます。
            </p>
          </div>
          <div class="bg-gradient-to-br from-red-100 to-red-50 rounded-lg p-6 shadow-md border-t-4 border-red-500">
            <div class="text-5xl mb-4 text-center">🧠</div>
            <h3 class="text-xl font-bold text-blue-800 mb-3 text-center">脳トレ×運動</h3>
            <p class="text-gray-700 text-center">
              シナプソロジー®️とバランスボールで、脳と体の両方を同時に活性化。認知機能の維持にも効果的です。
            </p>
          </div>
          <div class="bg-gradient-to-br from-blue-100 to-blue-50 rounded-lg p-6 shadow-md border-t-4 border-blue-500">
            <div class="text-5xl mb-4 text-center">😊</div>
            <h3 class="text-xl font-bold text-blue-800 mb-3 text-center">笑顔あふれる場所</h3>
            <p class="text-gray-700 text-center">
              インストラクターの温かい指導で、一人ひとりが安心して楽しめる環境を大切にしています。
            </p>
          </div>
        </div>
      </section>

      {/* CVエリア */}
      <section class="bg-gradient-to-r from-yellow-400 via-yellow-300 to-yellow-400 rounded-lg p-8 text-center shadow-xl">
        <h2 class="text-3xl font-bold text-blue-900 mb-4">
          まずは体験レッスンから、一緒に踊りませんか？
        </h2>
        <p class="text-blue-800 text-lg mb-6">
          どんな小さな疑問も公式LINEで受付中！インストラクターが直接丁寧にお答えします。
        </p>
        <Button href="#" text="LINEで今すぐ相談・体験申込" style="primary" />
      </section>

    </div>
  </main>
</Layout>