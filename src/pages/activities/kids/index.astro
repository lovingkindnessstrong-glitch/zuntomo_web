---
import Layout from '../../../layouts/Layout.astro';
import Button from '../../../components/Button.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import { Image } from 'astro:assets';

// キッズダンス用のヒーロー画像をインポート
import kidsHero from '../../../assets/images/activities/kids/kids-hero-1280.webp';

const breadcrumbItems = [
  { label: 'ホーム', href: '/' },
  { label: 'レッスン', href: '/#lesson' },
  { label: 'キッズクラス' },
];
---

<Layout title="キッズクラス | ZUNTOMO">
  <main class="bg-gradient-to-b from-yellow-50 via-green-50 to-white">
    
{/* ① ヒーローエリア */}
    <section class="relative w-full h-96 overflow-hidden flex flex-col items-center justify-center text-center px-4">
      {/* 背景画像： 縦の位置をパーセントで微調整（例: 20%） */}
      <Image 
        src={kidsHero} 
        alt="キッズダンスレッスンの様子" 
        class="absolute inset-0 h-full w-full object-cover object-[center_20%]"
      />
      {/* 半透明オーバーレイ（キッズの明るい雰囲気を残すため薄めの40%） */}
      <div class="absolute inset-0 bg-black/40"></div>
      
      {/* テキストコンテンツ */}
      <div class="relative z-10">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4 drop-shadow-[0_4px_4px_rgba(0,0,0,0.8)]">
          お子様の基礎能力を伸ばす、楽しいダンスレッスン
        </h1>
        <p class="text-lg md:text-xl text-yellow-50 max-w-3xl drop-shadow-[0_2px_2px_rgba(0,0,0,0.8)]">
          初めてのダンス習い事にぴったり！「基礎」と「楽しさ」を育む教室
        </p>
      </div>
    </section>
        
    <Breadcrumb items={breadcrumbItems} />

    <div class="container mx-auto px-4 py-12 max-w-6xl">
      
      {/* ② コンセプト・ストーリー */}
      <section class="mb-16">
        <h2 class="text-3xl font-bold text-green-800 border-b-4 border-yellow-400 pb-3 mb-6">
          🌱 ZUNTOMOキッズの想い
        </h2>
        <div class="bg-gradient-to-br from-yellow-50 to-green-50 rounded-lg p-8 shadow-md">
          <div class="space-y-6">
            <div>
              <h3 class="text-xl font-bold text-green-700 mb-3">🎯 土台を作るカリキュラム</h3>
              <p class="text-gray-800 text-lg leading-relaxed">
                柔軟、アイソレーション、リズムトレーニングといった基礎に加え、ヒップホップ、ブレイキン、シャッフルダンスなどの主要ステップを満遍なく取り入れています。ZUNTOMOオリジナルの「S-dance」も交え、子供たちが飽きずに楽しめる工夫が満載です。
              </p>
            </div>
            
            <div>
              <h3 class="text-xl font-bold text-green-700 mb-3">🏛️ 公共施設で安心スタート</h3>
              <p class="text-gray-800 text-lg leading-relaxed">
                「いきなり専門のスタジオに通うのはハードルが高い」という方に。まずは公共施設の教室で楽しくダンスの素養を養い、才能や興味が伸びた子は次のステップ（民間スタジオ）へ進むための「最初の土台作り」をお手伝いします。
              </p>
            </div>
            
            <div>
              <h3 class="text-xl font-bold text-green-700 mb-3">🌟 地域イベントで輝く</h3>
              <p class="text-gray-800 text-lg leading-relaxed">
                練習の成果を発揮する場として、地域のイベントへの出演も積極的に行っています。大きなステージで踊る感動を一緒に味わいましょう。
              </p>
            </div>
          </div>
        </div>
      </section>

      {/* ③ 募集期間のお知らせ（目立つデザイン） */}
      <section class="mb-12">
        <div class="bg-gradient-to-r from-yellow-400 via-orange-400 to-yellow-400 rounded-lg p-6 shadow-xl text-center">
          <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">
            📢 生徒募集中！
          </h2>
          <p class="text-xl text-white font-semibold mb-2">
            募集期間：<span class="text-2xl">3月・6月・9月・12月</span>
          </p>
          <p class="text-white text-lg">
            年4回の募集機会（主催：シンコースポーツ）<br>
            ※現在は次期募集に向けた準備期間です
          </p>
        </div>
      </section>

      {/* ④ クラス詳細カード */}
      <section class="mb-16">
        <h2 class="text-3xl font-bold text-green-800 border-b-4 border-yellow-400 pb-3 mb-6">
          📅 定期教室スケジュール（清水町温水プール）
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {/* カード1: 幼児〜小1 */}
          <div class="bg-white rounded-lg shadow-lg overflow-hidden border-t-4 border-yellow-500 hover:shadow-2xl transition-shadow duration-300">
            <div class="bg-gradient-to-r from-yellow-400 to-yellow-500 p-4">
              <h3 class="text-2xl font-bold text-white text-center">🧒 幼児・低学年クラス</h3>
            </div>
            <div class="p-6">
              <div class="space-y-4 mb-4">
                <div>
                  <p class="text-gray-800"><strong class="text-gray-900">👶 対象:</strong></p>
                  <p class="text-xl font-bold text-yellow-600">4歳〜小学1年生</p>
                </div>
                
                <div>
                  <p class="text-gray-800"><strong class="text-gray-900">⏰ 時間:</strong></p>
                  <p class="text-xl font-bold text-yellow-600">火曜日 16:00〜16:50</p>
                  <p class="text-gray-600 text-sm">（50分）</p>
                </div>
                
                <div>
                  <p class="text-gray-800"><strong class="text-gray-900">💰 料金:</strong></p>
                  <p class="text-2xl font-bold text-green-600">8,000円</p>
                  <p class="text-gray-600 text-sm">全10回分（初回に現金一括）</p>
                </div>
              </div>

              <div class="flex flex-wrap gap-2 mt-4 pt-4 border-t">
                <span class="bg-yellow-100 text-yellow-700 text-xs font-medium px-3 py-1.5 rounded-full">初めてのダンス</span>
                <span class="bg-yellow-100 text-yellow-700 text-xs font-medium px-3 py-1.5 rounded-full">基礎体力アップ</span>
                <span class="bg-yellow-100 text-yellow-700 text-xs font-medium px-3 py-1.5 rounded-full">楽しいレッスン</span>
              </div>
            </div>
          </div>

          {/* カード2: 小学生 初級 */}
          <div class="bg-white rounded-lg shadow-lg overflow-hidden border-t-4 border-green-500 hover:shadow-2xl transition-shadow duration-300">
            <div class="bg-gradient-to-r from-green-400 to-green-500 p-4">
              <h3 class="text-2xl font-bold text-white text-center">👦 小学生クラス（初級）</h3>
            </div>
            <div class="p-6">
              <div class="space-y-4 mb-4">
                <div>
                  <p class="text-gray-800"><strong class="text-gray-900">👧 対象:</strong></p>
                  <p class="text-xl font-bold text-green-600">小学生</p>
                </div>
                
                <div>
                  <p class="text-gray-800"><strong class="text-gray-900">⏰ 時間:</strong></p>
                  <p class="text-xl font-bold text-green-600">火曜日 17:00〜17:50</p>
                  <p class="text-gray-600 text-sm">（50分）</p>
                </div>
                
                <div>
                  <p class="text-gray-800"><strong class="text-gray-900">💰 料金:</strong></p>
                  <p class="text-2xl font-bold text-green-600">8,000円</p>
                  <p class="text-gray-600 text-sm">全10回分（初回に現金一括）</p>
                </div>
              </div>

              <div class="flex flex-wrap gap-2 mt-4 pt-4 border-t">
                <span class="bg-green-100 text-green-700 text-xs font-medium px-3 py-1.5 rounded-full">主要ステップ</span>
                <span class="bg-green-100 text-green-700 text-xs font-medium px-3 py-1.5 rounded-full">リズム感向上</span>
                <span class="bg-green-100 text-green-700 text-xs font-medium px-3 py-1.5 rounded-full">ダンス基礎</span>
              </div>
            </div>
          </div>

          {/* カード3: 高学年〜中学生 中級 */}
          <div class="bg-white rounded-lg shadow-lg overflow-hidden border-t-4 border-blue-500 hover:shadow-2xl transition-shadow duration-300">
            <div class="bg-gradient-to-r from-blue-400 to-blue-500 p-4">
              <h3 class="text-2xl font-bold text-white text-center">🧑 高学年・中学生クラス（中級）</h3>
            </div>
            <div class="p-6">
              <div class="space-y-4 mb-4">
                <div>
                  <p class="text-gray-800"><strong class="text-gray-900">🎓 対象:</strong></p>
                  <p class="text-xl font-bold text-blue-600">小学校高学年〜中学生</p>
                </div>
                
                <div>
                  <p class="text-gray-800"><strong class="text-gray-900">⏰ 時間:</strong></p>
                  <p class="text-xl font-bold text-blue-600">火曜日 18:00〜18:50</p>
                  <p class="text-gray-600 text-sm">（50分）</p>
                </div>
                
                <div>
                  <p class="text-gray-800"><strong class="text-gray-900">💰 料金:</strong></p>
                  <p class="text-2xl font-bold text-green-600">8,000円</p>
                  <p class="text-gray-600 text-sm">全10回分（初回に現金一括）</p>
                </div>
              </div>

              <div class="flex flex-wrap gap-2 mt-4 pt-4 border-t">
                <span class="bg-blue-100 text-blue-700 text-xs font-medium px-3 py-1.5 rounded-full">ステップ応用</span>
                <span class="bg-blue-100 text-blue-700 text-xs font-medium px-3 py-1.5 rounded-full">表現力アップ</span>
                <span class="bg-blue-100 text-blue-700 text-xs font-medium px-3 py-1.5 rounded-full">中級スキル</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      {/* ⑤ 共通案内セクション */}
      <section class="mb-16">
        <div class="bg-gradient-to-br from-blue-50 to-green-50 rounded-lg p-8 shadow-md border-l-4 border-green-500">
          <h2 class="text-2xl font-bold text-green-800 mb-6">📋 お申し込み方法</h2>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <h3 class="text-lg font-bold text-gray-800 mb-2">📍 会場</h3>
              <p class="text-gray-800 text-lg">清水町温水プール（清水町）</p>
            </div>
            
            <div>
              <h3 class="text-lg font-bold text-gray-800 mb-2">📝 申込方法</h3>
              <p class="text-gray-800 text-lg">
                募集期間（3月、6月、9月、12月）に、<br>
                清水町温水プールの窓口またはハガキにてご応募ください。
              </p>
            </div>
          </div>

          <div class="mt-6 p-4 bg-yellow-50 border-l-4 border-yellow-500 rounded">
            <p class="text-gray-800">
              <strong class="text-gray-900">💡 ポイント:</strong> 
              公共施設での開催のため、初めてダンスを習うお子様でも安心して通えます。基礎から丁寧に指導いたします。
            </p>
          </div>
        </div>
      </section>

      {/* ⑥ CTAエリア */}
      <section class="bg-gradient-to-r from-yellow-400 via-green-400 to-blue-400 rounded-lg p-8 text-center shadow-xl">
        <h2 class="text-3xl font-bold text-white mb-4">
          お子様の可能性を広げましょう！
        </h2>
        <p class="text-white text-lg mb-6">
          まずは体験レッスンから。お気軽にお問い合わせください。
        </p>
        <Button href="#" text="体験レッスンを申し込む" style="primary" />
      </section>

    </div>
  </main>
</Layout>