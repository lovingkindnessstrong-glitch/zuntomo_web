---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import tagsDict from '../../data/tags.json';

const breadcrumbItems = [
  { label: 'ホーム', href: '/' },
  { label: 'ブログ' },
];

// Astro.glob(...) の行を以下に差し替え
const allPosts = Object.values(import.meta.glob('./**/*.md', { eager: true })) as any[];

const sortedPosts = allPosts.sort((a: any, b: any) => {
  return new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf();
});

const allTags = [...new Set(allPosts.flatMap((post: any) => post.frontmatter.tags || []))];

const getTagUrl = (tagName: string) => {
  const dictData = (tagsDict as any)[tagName];
  const slug = dictData ? dictData.slug : encodeURIComponent(tagName);
  return `/blog/tags/${slug}/`;
};
---

<Layout title="ブログ | ZUNTOMO">
  <div class="bg-slate-50 min-h-screen pt-8 pb-20">
    <div class="container mx-auto px-4 max-w-5xl">
      <Breadcrumb items={breadcrumbItems} />
      
      <h1 class="text-3xl md:text-4xl font-bold text-slate-800 mb-8 mt-4">ブログ・活動報告</h1>
  {/* 💡タグのフィルタは反応を見て実装。それまではhidden */}
      <div class="hidden mb-10 bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
        <h2 class="text-sm font-bold text-slate-500 mb-3 flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
          タグで絞り込む
        </h2>
        <div class="flex flex-wrap gap-2">
          {allTags.map((tag: any) => (
            <a href={getTagUrl(tag)} class="inline-block bg-slate-100 hover:bg-emerald-100 hover:text-emerald-700 text-slate-600 px-4 py-2 rounded-full text-sm font-medium transition-colors">
              {tag}
            </a>
          ))}
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {sortedPosts.map((post: any) => (
          <a href={post.url} class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-all duration-300 border border-slate-100 hover:-translate-y-1 flex flex-col h-full">
            <div class="aspect-[4/3] overflow-hidden bg-slate-200">
              <img 
                src={post.frontmatter.heroImage || '/assets/images/common/default-ogp.webp'}
                alt={post.frontmatter.title}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
            </div>
            <div class="p-6 flex flex-col flex-grow">
              <div class="flex items-center justify-between mb-3">
                <time datetime={post.frontmatter.date} class="text-sm font-medium text-emerald-600">
                  {post.frontmatter.date}
                </time>
              </div>
              <h3 class="text-lg font-bold text-slate-800 mb-3 leading-snug group-hover:text-emerald-600 transition-colors">
                {post.frontmatter.title}
              </h3>
              
              <div class="mt-auto flex flex-wrap gap-1.5 pt-4">
                {(post.frontmatter.tags || []).map((tag: string) => (
                  <span class="inline-block bg-slate-50 border border-slate-200 text-slate-500 text-xs px-2 py-1 rounded-md">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>

    </div>
  </div>
</Layout>