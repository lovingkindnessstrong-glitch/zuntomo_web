---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>トップページ | ダンスサークル「ズンとも」</title>
  </head>
  <body class="bg-[#fdfbf7] text-slate-900">
    <Header />
    <main class="min-h-screen pt-4 md:pt-6">
      <section class="mx-auto max-w-6xl px-6 py-20 sm:px-8">
        <h1 class="text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">
          ダンスサークル「ズンとも」へようこそ
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">
          公式サイトのホームです。大人向けクラス、キッズクラス、運営情報、活動報告、動画アーカイブへの案内を掲載しています。
        </p>
      </section>
    </main>

    <Footer />
  </body>
</html>
