---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>トップページ | ダンスサークル「ズンとも」</title>
  </head>
  <body class="bg-[#fdfbf7] text-slate-900">
    <Header />
    
    <!-- ヒーローエリア -->
    <section class="hero-section relative h-96 w-full overflow-hidden md:h-[500px]">
      <img 
        src="/images/hero.png" 
        alt="ダンスの写真" 
        class="hero-image absolute inset-0 h-full w-full"
      />
      <div class="hero-overlay absolute inset-0"></div>
      <div class="hero-content absolute inset-0 flex items-center justify-center px-4 sm:px-6">
        <h1 class="text-center text-2xl font-bold text-white drop-shadow-lg sm:text-3xl md:text-5xl lg:text-6xl max-w-lg sm:max-w-2xl">
          ダンスサークル<br />「ズンとも」へようこそ
        </h1>
      </div>
    </section>
    
    <main class="min-h-screen pt-4 md:pt-6">
      <section class="mx-auto max-w-6xl px-6 py-20 sm:px-8">
        <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
          このサイトについて
        </h2>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">
          公式サイトのホームです。大人向けクラス、キッズクラス、運営情報、活動報告、動画アーカイブへの案内を掲載しています。
        </p>
      </section>

      <!-- クラス案内セクション -->
      <section class="mx-auto max-w-6xl px-6 py-12 sm:px-8 md:py-20">
        <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl mb-4">
          活動情報・クラス案内
        </h2>
        <p class="text-lg text-slate-600 mb-12">
          ズンともでは、大人向けと子ども向けの2つのクラスを開講しています。
        </p>

        <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
          <!-- 大人向けクラスカード -->
          <article class="class-card rounded-lg border border-slate-200 bg-white p-8 shadow-sm transition hover:shadow-md hover:-translate-y-1">
            <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-full bg-emerald-100">
              <svg class="h-6 w-6 text-emerald-600" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/>
              </svg>
            </div>
            <h3 class="text-2xl font-bold text-slate-900">
              大人向けクラス
            </h3>
            <p class="mt-4 text-base text-slate-600">
              運動が苦手な方も大歓迎！仲間と一緒に楽しく汗を流しましょう。初心者から経験者まで、みんなで楽しめるクラスです。
            </p>
            <a
              href="/about/"
              class="mt-6 inline-flex items-center justify-center rounded-lg bg-emerald-500 px-6 py-2 text-sm font-semibold text-white transition hover:bg-emerald-600"
            >
              詳細を見る
            </a>
          </article>

          <!-- キッズクラスカード -->
          <article class="class-card rounded-lg border border-slate-200 bg-white p-8 shadow-sm transition hover:shadow-md hover:-translate-y-1">
            <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-full bg-pink-100">
              <svg class="h-6 w-6 text-pink-600" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
              </svg>
            </div>
            <h3 class="text-2xl font-bold text-slate-900">
              キッズクラス
            </h3>
            <p class="mt-4 text-base text-slate-600">
              子どもたちの楽しい時間を応援します。ダンスを通じて、リズム感や表現力を育みながら、みんなで楽しく踊ります。
            </p>
            <a
              href="/kids/"
              class="mt-6 inline-flex items-center justify-center rounded-lg bg-pink-500 px-6 py-2 text-sm font-semibold text-white transition hover:bg-pink-600"
            >
              詳細を見る
            </a>
          </article>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  .hero-image {
    object-fit: cover;
    object-position: center;
  }

<style>
  .hero-image {
    object-fit: cover;
    object-position: center;
  }

  .hero-overlay {
    background-color: rgba(0, 0, 0, 0.35);
  }

  .hero-content {
    z-index: 10;
  }

  .class-card {
    display: flex;
    flex-direction: column;
    transition: all 0.3s ease-in-out;
  }

  .class-card:hover {
    border-color: rgba(16, 185, 129, 0.3);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
  }
</style>
