---
interface Props {
  items: {
    label: string;
    href?: string;
  }[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="container mx-auto px-4 py-4 max-w-5xl">
  <ol class="flex flex-wrap items-center space-x-2 text-sm text-gray-600">
    {items.map((item, index) => (
      <li class="flex items-center">
        {index > 0 && <span class="mx-2 text-gray-400">/</span>}
        {item.href ? (
          <a href={item.href} class="hover:text-blue-600 transition-colors">
            {item.label}
          </a>
        ) : (
          <span class="text-gray-800 font-medium" aria-current="page">
            {item.label}
          </span>
        )}
      </li>
    ))}
  </ol>
</nav>
