---
const sitemapLinks = [
  { href: '/', label: 'ホーム' },
  { href: '/activities/standard', label: '活動情報・クラス案内' },
  { href: '/about/', label: 'ズンともについて' },
  { href: '/news/', label: '活動報告' },
  { href: '/library/', label: 'レッスン動画' },
];

const LINE_URL = 'https://line.me/R/ti/p/@zuntomo';
---

<footer class="border-t border-slate-200 bg-white">
  <div class="mx-auto max-w-6xl px-6 py-12 sm:px-8">
    <!-- メインコンテンツグリッド -->
    <div class="grid grid-cols-1 gap-12 md:grid-cols-3">
      <!-- Column 1: Circle Info -->
      <div class="flex flex-col">
        <h2 class="text-2xl font-bold text-slate-900">
          ダンスサークル<br />「ズンとも」
        </h2>
        <p class="mt-4 text-base leading-7 text-slate-600">
          誰もが自分のペースで楽しめる、あなたのためのダンスコミュニティ。
        </p>
      </div>

      <!-- Column 2: Sitemap -->
      <div>
        <h3 class="text-lg font-semibold text-slate-900">
          ナビゲーション
        </h3>
        <nav class="mt-6">
          <ul class="space-y-3">
            {sitemapLinks.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class="text-base text-slate-600 transition hover:text-emerald-600 hover:underline"
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>

      <!-- Column 3: Action -->
      <div class="flex flex-col items-start md:items-end">
        <a
          href={LINE_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg bg-emerald-500 px-6 py-3 text-base font-semibold text-white transition hover:bg-emerald-600"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/>
          </svg>
          LINEでお問い合わせ
        </a>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-12 border-t border-slate-200 pt-8 text-center text-sm text-slate-600">
      © 2026 ダンスサークル「ズンとも」. All rights reserved.
    </div>
  </div>
</footer>
