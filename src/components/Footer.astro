---
const sitemapLinks = [
  { href: '/', label: 'HOME' },
  { href: '/#lesson', label: 'LESSON' },
  { href: '#', label: 'NEWS' },
  { href: '#', label: 'LIBRARY' },
];

const activityLinks = [
  { href: '/activities/standard/', label: '大人クラス' },
  { href: '/activities/kids/', label: 'キッズクラス' },
  { href: '/activities/gold/', label: 'ゴールドクラス' },
  { href: '/activities/salsa/', label: 'サルサ・バチャータ' },
  { href: '/activities/neko-odori/', label: '猫おどり部' },
];

const LINE_URL = 'https://line.me/R/ti/p/@zuntomo';
---

<footer class="border-t border-slate-200 bg-white">
  <div class="mx-auto max-w-6xl px-6 py-12 sm:px-8">
    <!-- メインコンテンツグリッド -->
    <div class="grid grid-cols-1 gap-12 md:grid-cols-3">
      <!-- Column 1: Circle Info -->
      <div class="flex flex-col">
        <h2 class="text-2xl font-bold text-slate-900">
          ダンスサークル<br />「ズンとも」
        </h2>
        <p class="mt-4 text-base leading-7 text-slate-600">
          誰もが自分のペースで楽しめる、あなたのためのダンスコミュニティ。
        </p>
      </div>

      <!-- Column 2: Sitemap -->
      <div>
        <h3 class="text-lg font-semibold text-slate-900">
          ナビゲーション
        </h3>
        <nav class="mt-6">
          <ul class="space-y-3">
            {sitemapLinks.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class="text-base text-slate-600 transition hover:text-emerald-600 hover:underline"
                >
                  {label}
                </a>
              </li>
            ))}
            <li class="pt-2">
              <a
                href="/privacy/"
                class="text-base text-slate-600 transition hover:text-emerald-600 hover:underline"
              >
                プライバシーポリシー
              </a>
            </li>
          </ul>
        </nav>
      </div>

      <!-- Column 3: Activities -->
      <div>
        <h3 class="text-lg font-semibold text-slate-900">
          レッスン一覧
        </h3>
        <nav class="mt-6">
          <ul class="space-y-3">
            {activityLinks.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class="text-base text-slate-600 transition hover:text-emerald-600 hover:underline"
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-12 border-t border-slate-200 pt-8 text-center text-sm text-slate-600">
      © 2026 ダンスサークル「ズンとも」. All rights reserved.
    </div>
  </div>
</footer>