---
import logoImage from '../assets/images/common/logo.svg';

const navLinks = [
  { href: '/', label: 'HOME' },
  { href: '/about/', label: 'ABOUT' },
  { href: '/guide/', label: 'GUIDE' },
  {
    href: '/#lesson',
    label: 'LESSON',
    children: [
      { href: '/activities/standard/', label: '大人クラス' },
      { href: '/activities/kids/', label: 'キッズクラス' },
      { href: '/activities/gold/', label: 'ゴールドクラス' },
      { href: '/activities/salsa/', label: 'サルサ・バチャータ' },
      { href: '/activities/neko-odori/', label: '猫おどり部' },
    ],
  },
  { href: '#', label: 'NEWS' },
  { href: '#', label: 'LIBRARY' },
];
---

<header class="sticky top-0 z-50 bg-white/95 shadow-sm">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-1 md:px-6">
    
    {/* ▼ 修正箇所：Tailwindクラス（h-16 md:h-20 = スマホで高さ64px、PCで80px）でサイズを直接指定 */}
    <a href="/" class="flex items-center transition-opacity hover:opacity-80" aria-label="ズンともホーム">
      <img src={logoImage.src} alt="ズンとも" class="h-16 md:h-20 w-auto" />
    </a>

    <nav class="hidden md:flex md:items-center md:gap-8" aria-label="Primary navigation">
      {navLinks.map((link) => (
        link.children ? (
          <div class="relative group py-4">
            <a href={link.href} class="text-sm font-medium text-slate-700 transition hover:text-slate-900 flex items-center gap-1">
              {link.label}
              <svg class="h-4 w-4 text-slate-400 group-hover:text-slate-600 transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </a>
            <div class="absolute left-1/2 -translate-x-1/2 top-full z-50 w-48 rounded-xl bg-white py-2 shadow-xl ring-1 ring-black/5 transition-all duration-200 opacity-0 invisible group-hover:opacity-100 group-hover:visible">
              {link.children.map((child) => (
                <a href={child.href} class="block px-4 py-2.5 text-sm text-slate-600 transition hover:bg-slate-50 hover:text-slate-900">
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a href={link.href} class="text-sm font-medium text-slate-700 transition hover:text-slate-900 py-4">
            {link.label}
          </a>
        )
      ))}
    </nav>

    <div class="flex items-center gap-2 md:gap-3">
      <a
        href="#"
        class="inline-flex items-center justify-center rounded-full bg-[#06C755] px-3 py-2 text-sm font-semibold text-white transition hover:bg-emerald-500 md:px-5"
      >
        <svg class="h-5 w-5 md:hidden" viewBox="0 0 24 24" fill="currentColor" aria-label="LINE申込">
          <path d="M12 2C6.48 2 2 6.48 2 12c0 5.52 4.48 10 10 10s10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z"/>
        </svg>
        <span class="hidden md:inline">LINEで体験申込</span>
      </a>

      <button
        id="header-menu-button"
        type="button"
        aria-label="メニューを開閉"
        aria-expanded="false"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-700 shadow-sm transition hover:bg-slate-50 md:hidden"
      >
        <span class="sr-only">メニュー</span>
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" />
        </svg>
      </button>
    </div>
  </div>

  <nav id="mobile-menu" class="hidden border-t border-slate-200 bg-white/95 px-4 pb-4 md:hidden" aria-label="Mobile navigation">
    <div class="flex flex-col gap-2 pt-3">
      {navLinks.map((link) => (
        link.children ? (
          <div>
            <a href={link.href} class="block rounded-2xl px-4 py-3 text-sm font-semibold text-slate-800 transition hover:bg-slate-100">
              {link.label}
            </a>
            <div class="ml-4 flex flex-col gap-1 border-l-2 border-slate-100 pl-4 py-1">
              {link.children.map((child) => (
                <a href={child.href} class="rounded-xl px-4 py-2 text-sm font-medium text-slate-600 transition hover:bg-slate-50 hover:text-slate-900">
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a href={link.href} class="rounded-2xl px-4 py-3 text-sm font-medium text-slate-700 transition hover:bg-slate-100">
            {link.label}
          </a>
        )
      ))}
      <a
        href="#"
        class="mt-2 inline-flex w-full items-center justify-center rounded-full bg-[#06C755] px-4 py-3 text-sm font-semibold text-white transition hover:bg-emerald-500"
      >
        LINE申込
      </a>
    </div>
  </nav>

  <script>
    const button = document.getElementById('header-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');

    if (button && mobileMenu) {
      button.addEventListener('click', () => {
        const isOpen = mobileMenu.classList.toggle('hidden');
        button.setAttribute('aria-expanded', String(!isOpen));
      });
    }
  </script>
</header>